rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /movie-posters/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
